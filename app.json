{
  "name": "Telegram WhatsApp Bot (Pure Python)",
  "description": "100% Python Telegram to WhatsApp forwarder",
  "repository": "https://github.com/yourusername/telegram-whatsapp-python",
  "keywords": ["python", "telegram", "whatsapp", "mongodb"],
  "env": {
    "TELEGRAM_BOT_TOKEN": {
      "description": "Telegram Bot Token",
      "required": true
    },
    "MONGODB_URI": {
      "description": "MongoDB connection URI",
      "required": true
    },
    "TARGET_WHATSAPP_JID": {
      "description": "Target WhatsApp JID",
      "required": true
    },
    "WHATSAPP_API_KEY": {
      "description": "API Key for security",
      "generator": "secret",
      "required": true
    },
    "ADMIN_TELEGRAM_IDS": {
      "description": "Admin Telegram IDs (comma-separated)",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
